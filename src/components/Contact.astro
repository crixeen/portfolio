---

<section id='contact'>

	<div class='section-tag'>Contacto</div>

	<h2 class='section-title'>
		¿Buscas un<br />desarrollador <em>para tu equipo?</em>
	</h2>

	<div class='contact-layout'>

		<div class='contact-left reveal'>

			<p class='section-sub' style='margin-bottom:0;'>
				Si estás buscando incorporar talento a tu empresa o tienes un proyecto en el que pueda sumar, escríbeme. Estoy disponible para oportunidades laborales y
				colaboraciones.
			</p>

			<div class='contact-info'>

				<a href='mailto:cristianjosue0506@gmail.com' class='contact-opt'>

					<span class='contact-opt-icon'>⌥</span>

					<div>

						<div class='contact-opt-label'>Email</div>

						<div class='contact-opt-val'>cristianjosue0506@gmail.com</div>

					</div>

					<span class='contact-opt-arr'>→</span>

				</a>

				<a href='https://github.com/crixeen' target='_blank' class='contact-opt'>

					<span class='contact-opt-icon'>⌥</span>

					<div>

						<div class='contact-opt-label'>GitHub</div>

						<div class='contact-opt-val'>github.com/crixen</div>

					</div>

					<span class='contact-opt-arr'>→</span>

				</a>

				<a href='https://linkedin.com/in/crixen' target='_blank' class='contact-opt'>

					<span class='contact-opt-icon'>⌥</span>

					<div>

						<div class='contact-opt-label'>LinkedIn</div>

						<div class='contact-opt-val'>linkedin.com/in/crixen</div>

					</div>

					<span class='contact-opt-arr'>→</span>

				</a>

			</div>

			<div class='contact-schedule' style='margin-top:2rem;'>

				<div class='contact-schedule-title'>// Horario de atención</div>

				<div class='schedule-rows'>

					<div class='schedule-row'>
						<span class='schedule-day'>Lunes – Viernes</span>
						<span class='schedule-time'>8:00 AM – 10:00 PM</span>
					</div>

					<div class='schedule-row'>
						<span class='schedule-day'>Sábado</span>
						<span class='schedule-time'>10:00 AM – 8:00 PM</span>
					</div>

					<div class='schedule-row'>
						<span class='schedule-day schedule-closed'>Domingo</span>
						<span class='schedule-time schedule-closed'>Cerrado</span>
					</div>

				</div>

			</div>

		</div>

		<div class='contact-right reveal reveal-delay-1'>

			<form class='contact-form' id='contactForm' name='contacto' method='post' data-netlify='true' data-netlify-honeypot='bot-field'>

  				<input type='hidden' name='form-name' value='contacto' />
  				<input type='hidden' name='bot-field' />

				<div class='form-row'>

					<div class='form-group'>
						<label class='form-label'>Nombre</label>
						<input class='form-input' type='text' name='nombre' placeholder='Tu nombre' required />
					</div>

					<div class='form-group'>
						<label class='form-label'>Empresa</label>
						<input class='form-input' type='text' name='empresa' placeholder='Nombre de tu empresa' />
					</div>

				</div>

				<div class='form-group'>
					<label class='form-label'>Email</label>
					<input class='form-input' type='email' name='email' placeholder='tu@empresa.com' required />
				</div>

				<div class='form-group'>
					<label class='form-label'>Asunto</label>
					<input class='form-input' type='text' name='asunto' placeholder='Ej: Oportunidad laboral / Proyecto' />
				</div>

				<div class='form-group'>
					<label class='form-label'>Mensaje</label>
					<textarea class='form-textarea' name='mensaje' placeholder='Cuéntame sobre tu empresa o el rol que tienes en mente...' required></textarea>
				</div>

				<button type='submit' class='form-submit' id='formSubmitBtn'> Enviar mensaje ✦ </button>

			</form>

		</div>

	</div>

</section>

<script src="../js/formValidation.js"></script>
