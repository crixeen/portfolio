---
import '/public/css/global.css';
import '/public/css/fonts.css';

interface Props {
	title?: string;
}

const { title = 'Cristian Josue · Crixeen — Desarrollador Web' } = Astro.props;
---

<!doctype html>
<html lang='es'>
	<head>
		<meta charset='UTF-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1.0' />
		<title>{title}</title>
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<meta name='description' content='Desarrollador Web Full Stack desde República Dominicana. Construyo experiencias digitales que hacen que la tecnología se sienta más clara y accesible.' />
	</head>
	<body>
		<div class='cursor' id='cursor'></div>
		<div class='cursor-ring' id='cursorRing'></div>
		<slot />
	</body>
</html>
